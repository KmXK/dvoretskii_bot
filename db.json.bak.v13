    "silenced_chats": {},
    "todo_items": [
        {
            "chat_id": -1002209945642,
            "id": 1,
            "is_done": true,
            "text": "прыгнуть на парашюте"
        },
        {
            "chat_id": -1002209945642,
            "id": 2,
            "is_done": true,
            "text": "Съехать на сноуборде с Эвереста, без кислорода (один раз можно использовать парашют)"
        },
        {
            "chat_id": -1002209945642,
            "id": 3,
            "is_done": false,
            "text": "съездить в брест"
        },
        {
            "chat_id": -1002209945642,
            "id": 4,
            "is_done": false,
            "text": "автотрип в бельгию"
        },
        {
            "chat_id": -1002209945642,
            "id": 5,
            "is_done": false,
            "text": "написать экстеншн для курсора чтобы можно было управлять курсором через руль"
        },
        {
            "chat_id": -1002209945642,
            "id": 6,
            "is_done": false,
            "text": "сходить на теннис"
        },
        {
            "chat_id": -1002209945642,
            "id": 7,
            "is_done": false,
            "text": "Снять яхту(обязательно с парусом) и без подготовки переплыть атлантический океан, пока плывём от Франции до Англии ВаняФ нас учит такелажу, а потом режим сложности: Сложный"
        },
        {
            "chat_id": -1002209945642,
            "id": 8,
            "is_done": false,
            "text": "сходить в крутое казино в костюмах и потом пойти есть шаву на вокзале"
        },
        {
            "chat_id": -1002209945642,
            "id": 9,
            "is_done": true,
            "text": "сходить в театр"
        },
        {
            "chat_id": -1002209945642,
            "id": 10,
            "is_done": false,
            "text": "купить костюмы для похода в театр и казино"
        },
        {
            "chat_id": -1002209945642,
            "id": 11,
            "is_done": false,
            "text": "сделать quarter zip как у эпштейна но со своими инициалами и бел флагом"
        },
        {
            "chat_id": -1002209945642,
            "id": 12,
            "is_done": false,
            "text": "на коньках в антарктиде покататься"
        },
        {
            "chat_id": -1002209945642,
            "id": 13,
            "is_done": true,
            "text": "сходить в лас легас"
        },
        {
            "chat_id": -1002209945642,
            "id": 14,
            "is_done": true,
            "text": "купить кока-колы"
        },
        {
            "chat_id": -1002209945642,
            "id": 15,
            "is_done": false,
            "text": "Пройти Камино де Сантьяго, но каждый километр выпиваешь банку пива"
        },
        {
            "chat_id": -1002209945642,
            "id": 16,
            "is_done": false,
            "text": "получить второе гражданство чтобы не запариваться о том что сдал паспорт в визовый центр"
        },
        {
            "chat_id": -1002209945642,
            "id": 17,
            "is_done": false,
            "text": "Мы все скидываемся по 20к$ и покупаем классный загородный дом под минском"
        },
        {
            "chat_id": -1002209945642,
            "id": 18,
            "is_done": false,
            "text": "доплыть до точки немо"
        },
        {
            "chat_id": -1002209945642,
            "id": 19,
            "is_done": false,
            "text": "приручить гепарда"
        },
        {
            "chat_id": -1002209945642,
            "id": 20,
            "is_done": false,
            "text": "слетать на остров Пасхи"
        },
        {
            "chat_id": -1002209945642,
            "id": 21,
            "is_done": false,
            "text": "Устроить Лёшку в яндексе чтобы он работал с курсором"
        },
        {
            "chat_id": -1002209945642,
            "id": 22,
            "is_done": false,
            "text": "стать президонтом страны, желательно Беларуси, но можно и какой-нибудь африканской"
        },
        {
            "chat_id": -1002209945642,
            "id": 23,
            "is_done": false,
            "text": "побывать на карнавале в Рио"
        },
        {
            "chat_id": -1002209945642,
            "id": 25,
            "is_done": false,
            "text": "покатать шары в боулинге"
        },
        {
            "chat_id": -1002209945642,
            "id": 26,
            "is_done": false,
            "text": "зарегистрировать несколько офшорных фирм и отмывать через них деньги полученные через баоботика (кого первым посадят - тот лох)"
        },
        {
            "chat_id": -1002209945642,
            "id": 27,
            "is_done": false,
            "text": "умереть в 27"
        },
        {
            "chat_id": -1002209945642,
            "id": 28,
            "is_done": false,
            "text": "Устроиться на работу матросом на краболовное судно в Норвегии и отработать хотя бы один полный сезон"
        },
        {
            "chat_id": -1002209945642,
            "id": 29,
            "is_done": false,
            "text": "Уехать жить смотрителем маяка куда нибудь на северные острова (если план \"умереть в 27\" не срабатывает)"
        },
        {
            "chat_id": -1002209945642,
            "id": 30,
            "is_done": false,
            "text": "поставить время быстрого круга по минскому мкаду не больше 15-ти минут"
        },
        {
            "chat_id": -1002209945642,
            "id": 31,
            "is_done": false,
            "text": "научиться делать сальто назад"
        },
        {
            "chat_id": -1002209945642,
            "id": 32,
            "is_done": false,
            "text": "стать геем под прикрытием, влиться с slay тусовку и трахнуть фембойчика"
        },
        {
            "chat_id": -1002209945642,
            "id": 33,
            "is_done": false,
            "text": "переплыть на сап борде минское море"
        },
        {
            "chat_id": -1002209945642,
            "id": 34,
            "is_done": false,
            "text": "add сходить в wood and fire"
        },
        {
            "chat_id": -1002209945642,
            "id": 35,
            "is_done": false,
            "text": "сдать цт"
        },
        {
            "chat_id": -1002209945642,
            "id": 36,
            "is_done": false,
            "text": "ночные гонки на жигулях по Минску (жигуль должен быть кастомизирован (нет крыши, огромные двухметровые рога, лимузин...))"
        },
        {
            "chat_id": -1002209945642,
            "id": 37,
            "is_done": false,
            "text": "съездить на ралли на затюненой фабии и намотаться на сосну"
        },
        {
            "chat_id": -1002209945642,
            "id": 38,
            "is_done": false,
            "text": "слетать на кур шавель покататься на сноубордах с мистером бистом и поиграть там в падел"
        },
        {
            "chat_id": -1003876657662,
            "id": 39,
            "is_done": false,
            "text": "стать собачкой и побегать по траве с росой"
        },
        {
            "chat_id": -1002209945642,
            "id": 40,
            "is_done": false,
            "text": "add съездить в киев (посмотреть город чисто)"
        },
        {
            "chat_id": -1002223126109,
            "id": 41,
            "is_done": false,
            "text": "ваня"
        },
        {
            "chat_id": -1002209945642,
            "id": 42,
            "is_done": false,
            "text": "побывать на технорейве в берлине"
        },
        {
            "chat_id": -1002209945642,
            "id": 43,
            "is_done": false,
            "text": "пересечь пустыню нелегалами на угольном товарнике (доп квест: взять с собой акулу, и что бы она выжила)"
        },
        {
            "chat_id": -1002209945642,
            "id": 44,
            "is_done": false,
            "text": "уйти в тибетский монастырь на 5 лет и обучаться искусству владения Кунг-фу у 300 летнего мастера"
        },
        {
            "chat_id": -1002209945642,
            "id": 45,
            "is_done": false,
            "text": "набить тату коричневого цвета на всю поверхность тела, типа ты негр"
        },
        {
            "chat_id": -1002209945642,
            "id": 46,
            "is_done": false,
            "text": "add прыгнуть на парашюте с эвереста"
        },
        {
            "chat_id": -1002209945642,
            "id": 47,
            "is_done": false,
            "text": "украсть осцилограф"
        },
        {
            "chat_id": -1002209945642,
            "id": 48,
            "is_done": false,
            "text": "открыть конторы по выдаче микрозаймов (работает по принципу банков, позволяет инвестировать деньги под большой процент)"
        },
        {
            "chat_id": -1002209945642,
            "id": 49,
            "is_done": false,
            "text": "уйти в буддистский монастырь и стать мастером кунг фу"
        }
    ],
    "user_facts": [
        {
            "created_at": 1777660666.3333106,
            "text": "Ему что-то делает Полина.",
            "user_id": 306979518
        },
        {
            "created_at": 1777660666.3333106,
            "text": "Он чувствует себя вынужденным есть это.",
            "user_id": 306979518
        },
        {
            "created_at": 1777660666.3333106,
            "text": "Он делится вакансией.",
            "user_id": 306979518
        },
        {
            "created_at": 1777660666.3333106,
            "text": "Он считает себя Владимиром Путиным.",
            "user_id": 306979518
        },
        {
            "created_at": 1777660666.3333106,
            "text": "У него есть никнейм @realUdachnik.",
            "user_id": 306979518
        },
        {
            "created_at": 1777665892.189846,
            "text": "У пользователя выходной.",
            "user_id": 5173407567
        },
        {
            "created_at": 1777665892.189846,
            "text": "Пользователь удивлён.",
            "user_id": 5173407567
        },
        {
            "created_at": 1777665892.189846,
            "text": "Пользователь потерял деньги сегодня.",
            "user_id": 5173407567
        },
        {
            "created_at": 1777665892.189846,
            "text": "Пользователя что-то очень злит.",
            "user_id": 5173407567
        },
        {
            "created_at": 1777703667.7066944,
            "text": "У него защемило спину.",
            "user_id": 645215512
        },
        {
            "created_at": 1777703667.7066944,
            "text": "Он любит свою мышь.",
            "user_id": 645215512
        },
        {
            "created_at": 1777703667.7066944,
            "text": "Он настроил зеллидж.",
            "user_id": 645215512
        },
        {
            "created_at": 1777703667.7066944,
            "text": "Он не понимает контекста.",
            "user_id": 645215512
        },
        {
            "created_at": 1777703667.7066944,
            "text": "Он кого-то обнаружил под домом.",
            "user_id": 645215512
        },
        {
            "created_at": 1777708384.4490905,
            "text": "Пользователю нравится дизайн Яндекс Музыки.",
            "user_id": 7619648412
        },
        {
            "created_at": 1777708384.4490905,
            "text": "Он использует OBS для долгих текстов.",
            "user_id": 7619648412
        },
        {
            "created_at": 1777708384.4490905,
            "text": "У него есть мышка MX Master.",
            "user_id": 7619648412
        },
        {
            "created_at": 1777708384.4490905,
            "text": "Ему неудобно долго писать обычной мышкой.",
            "user_id": 7619648412
        },
        {
            "created_at": 1777708384.4490905,
            "text": "У него болит запястье от обычной мышки.",
            "user_id": 7619648412
        },
        {
            "created_at": 1777708384.4490905,
            "text": "Крутое колесико у мышки MX Master.",
            "user_id": 7619648412
        },
        {
            "created_at": 1777708384.4490905,
            "text": "Пользователь сейчас не в Бресте.",
            "user_id": 7619648412
        },
        {
            "created_at": 1777708384.4490905,
            "text": "Мышка MX Master не очень удобна.",
            "user_id": 7619648412
        },
        {
            "created_at": 1777725881.2908156,
            "text": "Пользователь недоволен изменением времени напоминаний.",
            "user_id": 645215512
        },
        {
            "created_at": 1777742072.67324,
            "text": "Пользователь использует команду \"/ai\".",
            "user_id": 841595610
        },
        {
            "created_at": 1777742072.67324,
            "text": "Он задает оскорбительный вопрос.",
            "user_id": 841595610
        },
        {
            "created_at": 1777742090.700208,
            "text": "Пользователь критикует бота.",
            "user_id": 841595610
        },
        {
            "created_at": 1777746644.508206,
            "text": "(пусто)",
            "user_id": 685016046
        }
    ],
