TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Если задан — фронт переключается на новый Telegram Login (telegram-login.js, OIDC),
# и бэк валидирует id_token по JWKS Telegram. Получить можно в @BotFather → Bot Settings → Web Login.
# Если пусто — используется легаси Login Widget (telegram-widget.js + /setdomain).
TELEGRAM_LOGIN_CLIENT_ID=

# Для миниапп
# bore
DOMAIN=
ACME_EMAIL=

# Inline-режим (@бот <ссылка на тикток> в любом чате): Telegram принимает в
# inline-ответ только file_id уже загруженного файла, поэтому видео сначала
# заливается в служебный чат (сообщение сразу удаляется). По умолчанию — чат
# DbFeature.TARGET_CHAT_ID; чтобы не мелькало там, заведи приватный канал с
# ботом и укажи его id здесь.
# INLINE_UPLOAD_CHAT_ID=

# Метрики
METRICS_ENABLED=false
METRICS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# Yandex OCR (/newtext)
AI_VISION_KEY=
AI_VISION_SECRET=
YC_FOLDER_ID=

AI_MODEL_VLM=

NVIDIA_API_KEY=
# NVIDIA_SMART_MODEL=google/gemma-3-27b-it
# NVIDIA_FAST_MODEL=google/gemma-3-12b-it
# NVIDIA_OCR_MODEL=meta/llama-3.2-90b-vision-instruct

# Yandex SpeechKit STT — фолбек, когда ElevenLabs упал 3 раза подряд или кончились деньги.
# Если не задан AI_STT_KEY — берётся AI_KEY_SECRET. YC_FOLDER_ID см. выше.
# AI_STT_KEY=

# Бэкап метрик в Yandex Object Storage
YC_S3_KEY_ID=
YC_S3_KEY_SECRET=
YC_S3_BUCKET=your-bucket-name
BACKUP_INTERVAL=24h

# Сколько часов хранить "факты" о пользователе (короткая память AI). 0 — выключить.
USER_MEMORY_TTL_HOURS=24
# Собирать факты также из обычных сообщений в чате (не только после /ai)
USER_MEMORY_COLLECT_FROM_CHAT=true
# Минимальная длина сообщения-кандидата на извлечение
USER_MEMORY_COLLECT_MIN_LEN=15
# Сколько сообщений с личным сигналом копить перед одним batch-запросом к модели
USER_MEMORY_COLLECT_BATCH_SIZE=5
# Минимальный интервал между фоновыми извлечениями для одного пользователя
USER_MEMORY_COLLECT_COOLDOWN_SEC=1800

# /make_news — генерация AI-новостей с аватаром через EchoMimicV2 на Modal.
# Токен из ~/.modal.toml дев-машины (раздел [<profile>], token_id и token_secret).
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
# Провайдер TTS для /make_news: "yandex" (по дефолту, бесплатно при наличии AI_KEY_SECRET)
# или "elevenlabs" (нужен API ключ + voice id из voice library).
# NEWS_TTS_PROVIDER=yandex
# Голос для Yandex (madirus|ermil|filipp|zahar|jane|omazh). По умолчанию madirus.
# NEWS_TTS_VOICE=madirus
# ElevenLabs: ключ можно положить в EVELEN_LABS_STT (уже используется в проекте для ASR)
# или в ELEVENLABS_API_KEY. Voice ID берётся с https://elevenlabs.io/voice-library
# (выбираешь голос → ID копируется кнопкой). Модель по дефолту eleven_multilingual_v2 —
# топ по русскому. Тарифа free 10k символов/мес обычно хватает на ~20 минут речи.
# ELEVENLABS_API_KEY=
# NEWS_TTS_ELEVEN_VOICE_ID=
# NEWS_TTS_ELEVEN_MODEL=eleven_multilingual_v2
# Включить EchoMimic V2 анимацию аватара (по дефолту OFF — нужен Modal $30 free credit
# с привязкой карты). Без него используется эмоциональный статичный аватар.
# NEWS_VIDEO_ECHOMIMIC=1
