TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Для миниапп
# bore
DOMAIN=
ACME_EMAIL=

# Метрики
METRICS_ENABLED=false
METRICS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# Yandex OCR (/newtext)
AI_VISION_KEY=
AI_VISION_SECRET=
YC_FOLDER_ID=

AI_MODEL_VLM=

NVIDIA_API_KEY=
# NVIDIA_SMART_MODEL=google/gemma-3-27b-it
# NVIDIA_FAST_MODEL=google/gemma-3-12b-it
# NVIDIA_OCR_MODEL=meta/llama-3.2-90b-vision-instruct
# NVIDIA_STT_URL=
# NVIDIA_STT_MODEL=nvidia/parakeet-ctc-1.1b

# Бэкап метрик в Yandex Object Storage
YC_S3_KEY_ID=
YC_S3_KEY_SECRET=
YC_S3_BUCKET=your-bucket-name
BACKUP_INTERVAL=24h

# Сколько часов хранить "факты" о пользователе (короткая память AI). 0 — выключить.
USER_MEMORY_TTL_HOURS=24
# Собирать факты также из обычных сообщений в чате (не только после /ai)
USER_MEMORY_COLLECT_FROM_CHAT=true
# Минимальная длина сообщения-кандидата на извлечение
USER_MEMORY_COLLECT_MIN_LEN=15
# Сколько сообщений с личным сигналом копить перед одним batch-запросом к модели
USER_MEMORY_COLLECT_BATCH_SIZE=5
# Минимальный интервал между фоновыми извлечениями для одного пользователя
USER_MEMORY_COLLECT_COOLDOWN_SEC=1800
